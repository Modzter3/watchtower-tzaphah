NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# BullMQ / ioredis — use Upstash "Redis URL" (rediss://…), not the REST URL
REDIS_URL=

OPENAI_API_KEY=

NEWSAPI_KEY=
GNEWS_API_KEY=
GUARDIAN_API_KEY=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Max articles per fetch-news run (default in code is 25 if unset; max 50)
CRON_FETCH_BATCH=30

# 1 = skip prophetic relevance filter (testing only). Use 0 in production.
CRON_SKIP_RELEVANCE=0

# 1 = stricter AI relevance gate (fewer inserts). Default off = inclusive filter.
CRON_STRICT_RELEVANCE=0

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Same value in Vercel Production. External schedulers (e.g. every 15 min) must send:
#   Authorization: Bearer <CRON_SECRET>
# to GET /api/cron/fetch-news and GET /api/cron/process-queue on your production URL.
CRON_SECRET=
